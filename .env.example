# ============================================================
# Cloud Office – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- General ---
DOMAIN=meinedomain.de          # Your root domain
TZ=Europe/Berlin               # Server timezone

# --- Nextcloud ---
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change_me_strong_password_1

# --- Nextcloud Database (MariaDB) ---
MYSQL_ROOT_PASSWORD=change_me_root_pw
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=change_me_db_pw

# --- OnlyOffice ---
ONLYOFFICE_JWT_SECRET=change_me_onlyoffice_jwt_secret

# --- Vikunja ---
VIKUNJA_SERVICE_JWT_SECRET=change_me_vikunja_jwt_secret
VIKUNJA_DB_PASSWORD=change_me_vikunja_db_pw

# --- Nginx Proxy Manager ---
# Initial credentials after first login: admin@example.com / changeme
# Change immediately via the NPM web UI.
